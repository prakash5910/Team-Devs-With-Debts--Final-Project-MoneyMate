#:import dp kivy.metrics.dp
#:import GREEN_DARK components.theme.GREEN_DARK
#:import WHITE components.theme.WHITE
#:import TRANSPARENT components.theme.TRANSPARENT

<NavItem@BoxLayout>:
    icon: ""
    label: ""
    callback: None
    orientation: "vertical"
    padding: 0, dp(8)
    spacing: dp(2)
    Button:
        text: root.icon + "\n" + root.label
        font_size: dp(12)
        color: WHITE
        background_normal: ""
        background_color: TRANSPARENT
        halign: "center"
        valign: "middle"
        text_size: self.size
        on_release: root.callback() if root.callback else None

<BottomNavBar>:
    screen_manager: app.root
    orientation: "horizontal"
    size_hint_y: None
    height: dp(72)
    canvas.before:
        Color:
            rgba: GREEN_DARK
        Rectangle:
            pos: self.pos
            size: self.size
    NavItem:
        icon: "👤"
        label: "Account"
        callback: root.go_account
    NavItem:
        icon: "💬"
        label: "Contact Us"
        callback: root.go_contact
    NavItem:
        icon: "🚪"
        label: "Log Out"
        callback: root.do_logout
