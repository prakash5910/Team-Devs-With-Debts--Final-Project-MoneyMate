#:import dp kivy.metrics.dp
#:import GREEN_DARK components.theme.GREEN_DARK
#:import GREEN_MID components.theme.GREEN_MID
#:import WHITE components.theme.WHITE
#:import GRAY_LIGHT components.theme.GRAY_LIGHT
#:import GRAY_MID components.theme.GRAY_MID
#:import TEXT_DARK components.theme.TEXT_DARK
#:import RED components.theme.RED
#:import TRANSPARENT components.theme.TRANSPARENT

<LoginScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(28), 0
        canvas.before:
            Color:
                rgba: WHITE
            Rectangle:
                pos: self.pos
                size: self.size

        Widget:
            size_hint_y: None
            height: dp(48)

        Label:
            text: "MM"
            font_size: dp(42)
            bold: True
            color: GREEN_DARK
            size_hint_y: None
            height: dp(120)

        Label:
            text: "Welcome to"
            font_size: dp(22)
            color: TEXT_DARK
            size_hint_y: None
            height: dp(32)
        Label:
            text: "MONEY MATE"
            font_size: dp(30)
            bold: True
            color: TEXT_DARK
            size_hint_y: None
            height: dp(42)

        Widget:
            size_hint_y: None
            height: dp(20)

        TextInput:
            id: username_input
            hint_text: "Username"
            multiline: False
            size_hint_y: None
            height: dp(48)
            font_size: dp(16)
            padding: dp(16), dp(12)
            background_normal: ""
            background_color: GRAY_LIGHT
            foreground_color: TEXT_DARK
            hint_text_color: GRAY_MID
            cursor_color: GREEN_DARK

        Widget:
            size_hint_y: None
            height: dp(10)

        TextInput:
            id: password_input
            hint_text: "Password"
            password: True
            multiline: False
            size_hint_y: None
            height: dp(48)
            font_size: dp(16)
            padding: dp(16), dp(12)
            background_normal: ""
            background_color: GRAY_LIGHT
            foreground_color: TEXT_DARK
            hint_text_color: GRAY_MID
            cursor_color: GREEN_DARK
            on_text_validate: root.do_login()

        Label:
            id: error_label
            text: ""
            font_size: dp(12)
            color: RED
            size_hint_y: None
            height: dp(30)

        Button:
            text: "Log In"
            size_hint_y: None
            height: dp(50)
            font_size: dp(18)
            background_normal: ""
            background_color: GREEN_MID
            color: WHITE
            on_release: root.do_login()

        Widget:

        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(36)
            Label:
                text: "New user?"
                font_size: dp(13)
                color: GRAY_MID
            Button:
                text: "Sign Up here"
                font_size: dp(13)
                color: GREEN_MID
                background_normal: ""
                background_color: TRANSPARENT
                on_release: app.root.current = "signup"

        Label:
            text: "V.1.0.0"
            font_size: dp(11)
            color: GRAY_MID
            size_hint_y: None
            height: dp(28)
