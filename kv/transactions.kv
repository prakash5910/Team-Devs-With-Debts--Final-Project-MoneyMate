#:kivy 2.3.1

<TransactionsScreen>:
    table_body: table_body
    date_label: date_label

    canvas.before:
        Color:
            rgba: 0.96, 0.97, 0.98, 1
        Rectangle:
            size: self.size
            pos: self.pos

    BoxLayout:
        orientation: "vertical"

        # --- Header ---
        BoxLayout:
            size_hint_y: None
            height: dp(70)
            padding: [dp(20), dp(10)]
            canvas.before:
                Color:
                    rgba: 0.098, 0.235, 0.204, 1
                Rectangle:
                    size: self.size
                    pos: self.pos

            Button:
                text: "\ue5cb"
                font_name: "MaterialIcons"
                font_size: dp(32)
                size_hint: None, None
                size: dp(40), dp(40)
                pos_hint: {"center_y": .5}
                background_color: 0, 0, 0, 0
                on_release: root.manager.current = "dashboard"

            Label:
                text: "Recent Activity"
                font_size: dp(20)
                bold: True
                color: 1, 1, 1, 1
                halign: "left"
                text_size: self.size

        # --- History Filter Bar ---
        BoxLayout:
            size_hint_y: None
            height: dp(55)
            padding: [dp(25), dp(5)] # Increased left padding to align with cards
            spacing: dp(10)
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 1
                Rectangle:
                    size: self.size
                    pos: self.pos

            Label:
                id: date_label
                text: "Showing: All History"
                font_size: dp(14)
                color: 0.3, 0.3, 0.3, 1
                halign: "left"
                valign: "middle"
                text_size: self.size

            Button:
                text: "\ue916"
                font_name: "MaterialIcons"
                font_size: dp(24)
                size_hint: None, None
                size: dp(40), dp(40)
                pos_hint: {"center_y": .5}
                background_normal: ""
                background_color: 0.9, 0.92, 0.91, 1
                color: 0.098, 0.235, 0.204, 1
                on_release: root.show_date_filter_popup()

        # --- Transactions List ---
        ScrollView:
            do_scroll_x: False
            BoxLayout:
                id: table_body
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(20), dp(16)] # Added horizontal breathing room
                spacing: dp(12)

        # --- Add Transaction Button (LIFTED) ---
        AnchorLayout:
            anchor_x: "center"
            anchor_y: "center"
            size_hint_y: None
            height: dp(100) # Increased height to lift the button
            padding: [0, dp(15), 0, dp(25)] # Pushes button up from the bottom nav
            
            Button:
                text: "+ ADD TRANSACTION"
                size_hint: None, None
                size: dp(280), dp(50)
                bold: True
                color: 1, 1, 1, 1
                background_color: 0, 0, 0, 0
                on_release: root.show_add_popup()
                canvas.before:
                    Color:
                        rgba: 0.098, 0.235, 0.204, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(25)]

        # --- Bottom Nav ---
        BoxLayout:
            id: bottom_nav
            size_hint_y: None
            height: dp(65)