#:kivy 2.3.1

<DashboardScreen>:
    greeting_label: greeting_label
    month_label: month_label
    income_label: income_label
    expense_label: expense_label
    income_chart: income_chart
    expense_chart: expense_chart
    goals_container: goals_container

    canvas.before:
        Color:
            rgba: 0.96, 0.97, 0.98, 1
        Rectangle:
            size: self.size
            pos: self.pos

    BoxLayout:
        orientation: "vertical"

        # --- Header ---
        BoxLayout:
            size_hint_y: None
            height: dp(65)
            padding: [dp(20), dp(10)]
            canvas.before:
                Color:
                    rgba: 0.098, 0.235, 0.204, 1
                Rectangle:
                    size: self.size
                    pos: self.pos

            Label:
                id: greeting_label
                text: "Hello!"
                font_size: dp(20)
                bold: True
                halign: "left"
                text_size: self.size

            Image:
                source: "assets/logo.png"
                size_hint_x: None
                width: dp(35)

        # --- Top Navigation Bar ---
        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(85)
            padding: [dp(10), dp(5)]
            spacing: dp(4)
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 1
                Rectangle:
                    size: self.size
                    pos: self.pos
                Color:
                    rgba: 0.9, 0.9, 0.9, 1
                Line:
                    points: [self.x, self.y, self.right, self.y]
                    width: 1

            NavIcon:
                text_icon: "\ue871"
                label_text: "Dashboard"
                on_release: root.manager.current = "dashboard"
            NavIcon:
                text_icon: "\ue8b0"
                label_text: "Statements"
                on_release: root.manager.current = "statements"
            NavIcon:
                text_icon: "\ue850"
                label_text: "Transactions"
                on_release: root.manager.current = "transactions"
            NavIcon:
                text_icon: "\ue8b8"
                label_text: "Settings"
                on_release: root.manager.current = "settings"

        # --- Scrollable Body ---
        ScrollView:
            do_scroll_x: False
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                padding: dp(16)
                spacing: dp(20)

                Label:
                    id: month_label
                    text: "Monthly Summary"
                    bold: True
                    font_size: dp(18)
                    color: 0.1, 0.1, 0.1, 1
                    size_hint_y: None
                    height: dp(30)
                    halign: "left"
                    text_size: self.size

                # --- Income/Expense Card Row ---
                BoxLayout:
                    size_hint_y: None
                    height: dp(185)
                    spacing: dp(12)

                    DashboardCard:
                        Label:
                            text: "Income"
                            font_size: dp(13)
                            bold: True
                            color: 0.4, 0.4, 0.4, 1
                            size_hint_y: None
                            height: dp(25)
                        AnchorLayout:
                            id: income_chart
                        Label:
                            id: income_label
                            text: "$0.00"
                            bold: True
                            font_size: dp(16)
                            color: 0.18, 0.60, 0.40, 1
                            size_hint_y: None
                            height: dp(25)

                    DashboardCard:
                        Label:
                            text: "Expenses"
                            font_size: dp(13)
                            bold: True
                            color: 0.4, 0.4, 0.4, 1
                            size_hint_y: None
                            height: dp(25)
                        AnchorLayout:
                            id: expense_chart
                        Label:
                            id: expense_label
                            text: "$0.00"
                            bold: True
                            font_size: dp(16)
                            color: 0.85, 0.15, 0.15, 1
                            size_hint_y: None
                            height: dp(25)

                # --- Saving Goals Section ---
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(12)

                    Label:
                        text: "Saving Goals"
                        bold: True
                        font_size: dp(18)
                        color: 0.1, 0.1, 0.1, 1
                        size_hint_y: None
                        height: dp(30)
                        halign: "left"
                        text_size: self.size

                    BoxLayout:
                        id: goals_container
                        orientation: "vertical"
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(10)

        # --- Bottom Navigation ---
        BoxLayout:
            id: bottom_nav
            size_hint_y: None
            height: dp(65)

# --- Reusable Components ---
<NavIcon@ButtonBehavior+BoxLayout>:
    orientation: "vertical"
    text_icon: ""
    label_text: ""
    spacing: dp(2)
    Label:
        text: root.text_icon
        font_name: "MaterialIcons"
        font_size: dp(24)
        color: 0.098, 0.235, 0.204, 1
        canvas.before:
            Color:
                rgba: 0.92, 0.95, 0.94, 1
            Ellipse:
                pos: self.center_x - dp(20), self.center_y - dp(20)
                size: dp(40), dp(40)
    Label:
        text: root.label_text
        font_size: dp(10)
        color: 0.3, 0.3, 0.3, 1
        size_hint_y: None
        height: dp(15)

<DashboardCard@BoxLayout>:
    orientation: "vertical"
    padding: dp(12)
    spacing: dp(8)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [dp(12)]
        Color:
            rgba: 0, 0, 0, 0.05
        Line:
            rounded_rectangle: [self.x, self.y, self.width, self.height, dp(12)]
            width: 1.1