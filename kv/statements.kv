#:kivy 2.3.1

<StatementsScreen>:
    month_label: month_label
    income_total: income_total
    expense_total: expense_total
    balance_total: balance_total
    transaction_count: transaction_count

    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            size: self.size
            pos: self.pos

    BoxLayout:
        orientation: "vertical"

        # Header
        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(76)
            padding: [dp(16), dp(10)]
            spacing: dp(10)

            canvas.before:
                Color:
                    rgba: 0.098, 0.235, 0.204, 1
                Rectangle:
                    size: self.size
                    pos: self.pos

            Button:
                text: "<"
                font_size: dp(24)
                bold: True
                color: 1, 1, 1, 1
                background_normal: ""
                background_color: 0, 0, 0, 0
                size_hint: None, None
                size: dp(42), dp(50)
                on_press: root.manager.current = "dashboard"

            Label:
                text: "Statements"
                font_size: dp(20)
                bold: True
                color: 1, 1, 1, 1
                halign: "left"
                valign: "middle"
                text_size: self.size

            Image:
                source: "assets/logo.png"
                size_hint: None, None
                size: dp(38), dp(38)

        BoxLayout:
            orientation: "vertical"
            padding: [dp(28), dp(26)]
            spacing: dp(18)

            Widget:
                size_hint_y: None
                height: dp(10)

            Label:
                text: "Monthly Summary"
                font_size: dp(22)
                bold: True
                color: 0.1, 0.1, 0.1, 1
                size_hint_y: None
                height: dp(50)
                halign: "center"
                valign: "middle"
                text_size: self.size

            BoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: dp(44)
                spacing: dp(10)

                Label:
                    id: month_label
                    text: "Month: ---- --"
                    font_size: dp(16)
                    color: 0.45, 0.45, 0.45, 1
                    halign: "left"
                    valign: "middle"
                    text_size: self.size

                Button:
                    text: "Change"
                    font_size: dp(13)
                    size_hint: None, None
                    size: dp(90), dp(38)
                    background_normal: ""
                    background_color: 0.298, 0.686, 0.522, 1
                    color: 1, 1, 1, 1
                    on_press: root.show_month_popup()

            Label:
                text: "Income"
                font_size: dp(18)
                bold: True
                color: 0.18, 0.60, 0.40, 1
                size_hint_y: None
                height: dp(28)

            Label:
                id: income_total
                text: "$0.00"
                font_size: dp(30)
                bold: True
                color: 0.18, 0.60, 0.40, 1
                size_hint_y: None
                height: dp(44)

            Label:
                text: "Expenses"
                font_size: dp(18)
                bold: True
                color: 0.85, 0.15, 0.15, 1
                size_hint_y: None
                height: dp(28)

            Label:
                id: expense_total
                text: "$0.00"
                font_size: dp(30)
                bold: True
                color: 0.85, 0.15, 0.15, 1
                size_hint_y: None
                height: dp(44)

            Label:
                text: "Net Balance"
                font_size: dp(18)
                bold: True
                color: 0.1, 0.1, 0.1, 1
                size_hint_y: None
                height: dp(28)

            Label:
                id: balance_total
                text: "$0.00"
                font_size: dp(30)
                bold: True
                color: 0.098, 0.235, 0.204, 1
                size_hint_y: None
                height: dp(44)

            Label:
                id: transaction_count
                text: "0 transactions"
                font_size: dp(16)
                color: 0.55, 0.55, 0.55, 1
                size_hint_y: None
                height: dp(34)

            Button:
                text: "View Transactions"
                font_size: dp(17)
                bold: True
                size_hint_y: None
                height: dp(52)
                background_normal: ""
                background_color: 0.298, 0.686, 0.522, 1
                color: 1, 1, 1, 1
                on_press: root.manager.current = "transactions"

            Widget:

        BoxLayout:
            id: bottom_nav
            size_hint_y: None
            height: dp(82)